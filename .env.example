# Copy this file to .env and fill in your values.
# .env is gitignored so credentials and per-user identifiers stay local.

# REST endpoint of the DBRepo instance
DBREPO_ENDPOINT=https://test.dbrepo.tuwien.ac.at

# Your DBRepo (matriculation) username
DBREPO_USERNAME=

# Container id of the MariaDB instance backing your DBRepo database.
# Same for everyone using the TU Wien test instance.
DBREPO_CONTAINER_ID=6cfb3b8e-1792-4e46-871a-f3d103527203

# Database id of the working database.
# Leave empty until the database has been created; the upload notebook
# prints the id, paste it here afterwards so all other notebooks use it.
DBREPO_DATABASE_ID=

# Display name of the database (set during database creation).
DBREPO_DATABASE_NAME=SDCC Traffic Flow Experiment 2022

# Optional. If unset, scripts prompt interactively via getpass.
DBREPO_PASSWORD=
